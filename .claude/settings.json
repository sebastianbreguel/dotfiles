      }
    },
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "socraticode": {
      "source": {
        "source": "github",
        "repo": "giancarloerra/socraticode"
      }
    },
    "claude-subconscious": {
      "source": {
        "source": "github",
        "repo": "letta-ai/claude-subconscious"
      }
    }
  },
  "effortLevel": "medium",
  "autoUpdatesChannel": "stable",
  "voiceEnabled": true,
  "autoMemoryEnabled": false,
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "autoCompactThreshold": 0.6
}
